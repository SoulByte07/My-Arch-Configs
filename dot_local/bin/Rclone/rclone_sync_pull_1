#!/bin/bash

# --- Configuration ---
# Fixed the broken spaces in these paths
SOURCE="/sdcard/Backups/0_Sync"
REMOTE="EncryptGoogleDrive:0_Sync"
TIMESTAMP="$(date +%d-%b/%m-%y_%H-%M)"
#TRASH_DIR="EncryptGoogleDrive:96_Trash/0_Sync/$TIMESTAMP"
TRASH_DIR="/sdcard/Backups/96_Trash/0_Sync/$TIMESTAMP"
LOG_DIR="/sdcard/Documents/Logs/rclone"
DATE=$(date +%Y-%m-%d_%H-%M-%S)
LOG_FILE="$LOG_DIR/$DATE.log"

# --- Safety Checks ---
# 1. Ensure the log directory exists
mkdir -p "$LOG_DIR"

# 2. Check if the source directory is actually accessible
if [ ! -d "$SOURCE" ]; then
    echo "Error: Source directory $SOURCE not found."
    echo "Make sure you ran 'termux-setup-storage' and the folder exists."
    exit 1
fi

# --- Rclone Command ---
rclone sync "$REMOTE" "$SOURCE" \
    --fast-list \
    --backup-dir "$TRASH_DIR" \
    --create-empty-src-dirs \
    --log-file="$LOG_FILE" \
    --log-level INFO \
    --max-delete 50
    --use-mmap \
    --progress

echo "Sync complete. Log saved to $LOG_FILE"
