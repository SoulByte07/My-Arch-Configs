#!/bin/bash

# --- Configuration ---
# 1. DATE moved to top so other variables can use it.
# 2. Changed format to remove slashes (bad for filenames).
DATE=$(date +%d-%b-%m-%y_%H-%M)

SOURCE="$HOME/4_Backups/0_Sync"
REMOTE="EncryptGoogleDrive:0_Sync"
TRASH_DIR="EncryptGoogleDrive:96_Trash/0_Sync/$DATE"
LOG_DIR="$HOME/2_Resources/97_Logs/rclone"
LOG_FILE="$LOG_DIR/$DATE.log"

# --- Safety Check ---
# Create the log directory
mkdir -p "$LOG_DIR"

# --- Rclone Command ---
# Direction: Local Source -> Remote Destination
rclone sync "$SOURCE" "$REMOTE" \
    --fast-list \
    --backup-dir "$TRASH_DIR" \
    --create-empty-src-dirs \
    --log-file="$LOG_FILE" \
    --log-level INFO \
    --use-mmap \
    --progress

echo "Sync complete. Log saved to $LOG_FILE"
