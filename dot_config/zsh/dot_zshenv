# ~/.zshenv
export ZDOTDIR="$HOME/.config/zsh"

# Basic Paths
export EDITOR="nvim"
export VISUAL="nvim"
export SHELL="/usr/bin/zsh"

export CARGO_HOME="$HOME/.local/share/cargo"
export NPM_CONFIG_USERCONFIG="$HOME/.config/npm/npmrc"
