# npm
export PATH="$HOME/.local/share/npm/bin:$PATH"

export PATH="$CARGO_HOME/bin:$BUN_INSTALL/bin:$PATH"

# for custom user scripts 
export PATH="$HOME/.local/bin:$PATH"


export MANPAGER='nvim +Man!'
